# === Cataloging (Vision) ===
# Used by catalog.py to analyze clothing images
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# === Recommendations (Chat) ===
# Used by the chatbot to suggest outfits
# Default: Alibaba DashScope (Qwen). Change base URL in config.py for other providers.
# Get your key at: https://dashscope.console.aliyun.com/
CHAT_API_KEY=your_chat_api_key_here